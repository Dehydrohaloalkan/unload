              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202 or 409', function () {",
                  "  pm.expect([202, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 409) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Conflict returns errorCode', function () {",
                  "    pm.expect(body).to.have.property('errorCode');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Run By Correlation Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-get-run-by-id"
