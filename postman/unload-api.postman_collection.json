              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202 or 404', function () {",
                  "  pm.expect([202, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 404) {",
                  "  const body = pm.response.json();",
                  "  pm.test('Not found has RUN_NOT_FOUND code', function () {",
                  "    pm.expect(body.errorCode).to.eql('RUN_NOT_FOUND');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
