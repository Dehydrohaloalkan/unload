    {
      "name": "02 - Preset And Extra",
      "item": [
        {
          "name": "Run Preset",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-run-preset"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/runs/preset",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs",
                "preset"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 409', function () {",
                  "  pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Preset response contains scriptsExecuted', function () {",
                  "    pm.expect(body).to.have.property('scriptsExecuted');",
                  "    pm.expect(body).to.have.property('correlationId');",
                  "  });",
                  "} else {",
                  "  pm.test('Conflict has PRESET_GATE_BLOCKED or SCRIPT_TASK_CONFLICT', function () {",
                  "    pm.expect(['PRESET_GATE_BLOCKED', 'SCRIPT_TASK_CONFLICT']).to.include(body.errorCode);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Run Extra",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-run-extra"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/runs/extra",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs",
                "extra"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 409', function () {",
                  "  pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Extra response contains expected fields', function () {",
                  "    pm.expect(body).to.have.property('scriptsExecuted');",
                  "    pm.expect(body).to.have.property('filesWritten');",
                  "  });",
                  "} else {",
                  "  pm.test('Conflict has expected errorCode', function () {",
                  "    pm.expect(['PRESET_GATE_BLOCKED', 'SCRIPT_TASK_CONFLICT']).to.include(body.errorCode);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "03 - Edge Cases",
      "item": [
        {
          "name": "Start Main Run - Empty memberCodes",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "postman-start-main-empty-members"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberCodes\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/runs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 or 409', function () {",
                  "  pm.expect([400, 409]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Error contract has errorCode', function () {",
                  "  pm.expect(body).to.have.property('errorCode');",
                  "});",
                  "pm.test('Error code is validation or gate-related', function () {",
                  "  pm.expect(['VALIDATION_ERROR', 'PRESET_GATE_BLOCKED']).to.include(body.errorCode);",
                  "});"
                ]
              }
            }
          ],
          "response": []
