        {
          "name": "Stop Run By Correlation Id",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-stop-run-by-id"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/runs/{{correlationId}}/stop",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs",
                "{{correlationId}}",
