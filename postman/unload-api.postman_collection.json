{
  "info": {
    "_postman_id": "5b0d86b3-77e8-4f0a-9ebf-8e518b83d3a4",
    "name": "Unload API",
    "description": "Collection with smoke and edge-case tests for Unload API lifecycle.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Smoke",
      "item": [
        {
          "name": "Get Members",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-get-members"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/members",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "members"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Body is array', function () {",
                  "  pm.expect(Array.isArray(body)).to.eql(true);",
                  "});",
                  "if (Array.isArray(body) && body.length > 0 && body[0].code) {",
                  "  pm.collectionVariables.set('memberCode', body[0].code);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Preset State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-get-preset-state"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/runs/preset/state",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs",
                "preset",
                "state"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.test('Preset state has key fields', function () {",
                  "  pm.expect(body).to.have.property('enabled');",
                  "  pm.expect(body).to.have.property('pollingStarted');",
                  "  pm.expect(body).to.have.property('requiresPresetExecution');",
                  "  pm.expect(body).to.have.property('readyForPreset');",
                  "  pm.expect(body).to.have.property('presetCompleted');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Active Run",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-Id",
                "value": "postman-get-active-run"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/runs/active",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs",
                "active"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 404', function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body && body.correlationId) {",
                  "    pm.collectionVariables.set('correlationId', body.correlationId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "01 - Main Run Flow",
      "item": [
        {
          "name": "Start Main Run",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "postman-start-main"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberCodes\": [\"{{memberCode}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/runs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "runs"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 202 or 409', function () {",
                  "  pm.expect([202, 409]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "if (pm.response.code === 202) {",
                  "  pm.test('Accepted response has correlationId', function () {",
                  "    pm.expect(body).to.have.property('correlationId');",
                  "  });",
                  "  pm.collectionVariables.set('correlationId', body.correlationId);",
                  "} else {",
                  "  pm.test('Conflict includes ProblemDetails fields', function () {",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body).to.have.property('errorCode');",
                  "  });",
                  "  if (body.activeCorrelationId) {",
                  "    pm.collectionVariables.set('correlationId', body.activeCorrelationId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Start Main Run Again (conflict expected if already running)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "postman-start-main-again"
